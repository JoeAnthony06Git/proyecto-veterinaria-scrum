# Base de datos
DATABASE_URL="postgresql://usuario:password@localhost:5432/veterinaria"

# JWT
JWT_SECRET="cambiar-esta-clave-secreta-en-produccion"
JWT_EXPIRES_IN="7d"

# Puerto del servidor
PORT=3000

# IA - Gemini (gratis, 60 req/min)
# Obtén tu API key en: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIzaSy...

# IA - Ollama (local, alternativo a Gemini)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5

# IA - GROQ (gratis, 60 req/min)
# Obtén tu API key en: https://console.groq.com/keys
# GROQ_API_KEY= gsk_...